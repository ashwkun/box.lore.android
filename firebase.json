{
    "hosting": {
        "public": "docs/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "redirects": [
            {
                "source": "/boxlore/avatarlab",
                "destination": "/avatarlab/",
                "type": 301
            },
            {
                "source": "/boxlore/avatarlab/:path*",
                "destination": "/avatarlab/:path",
                "type": 301
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}